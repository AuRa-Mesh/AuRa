# Скопируйте в deploy.env и подставьте свои значения:
#   cp deploy.env.example deploy.env
#
# Деплой через Git:        ./deploy.sh
# Прямая заливка (rsync):  ./upload.sh   |  Windows: upload.bat
# (upload.sh не трогает server/aura_site.db на сервере — профили и VIP)
# SSH по ключу без пароля: docs/ssh-vps.md
# Необязательно: явный путь к приватному ключу (если не ~/.ssh/id_ed25519_aura)
# AURA_DEPLOY_IDENTITY=~/.ssh/id_ed25519_aura

# Подпись QR «восстановление профиля» (HMAC). Должно совпадать с AURA_PROFILE_QR_HMAC
# в Android local.properties. Не публикуйте секрет в JS.
# AURA_PROFILE_QR_HMAC=

# Счётчик «сборка N» на кнопке скачивания: upload.sh увеличивает apk_build.txt +1 при новом SHA256
# assets/AuRa.APK (локально). Состояние SHA: .apk_last_upload_sha (не в git).
# apk_build.txt можно коммитить, чтобы номер не сбрасывался между машинами.

# HMAC для подстановки &sig= в index.html (upload.sh). На сервере 403 делается только если ТАМ
# задано: AURA_APK_DOWNLOAD_HMAC + AURA_APK_DOWNLOAD_REQUIRE_SIG=1
# (см. override systemd; по умолчанию сколько ни задавай HMAC в env — /api/apk отдаёт APK).
# AURA_APK_DOWNLOAD_HMAC=

AURA_DEPLOY_SSH=root@YOUR_SERVER_IP
AURA_DEPLOY_PATH=/opt/aura/AuRa-deploy
AURA_DEPLOY_BRANCH=main
