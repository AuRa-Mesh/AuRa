<?xml version="1.0" encoding="utf-8"?>
<!--
    Правила извлечения данных (API 31+). VIP + прогрессия (уровень, медали) в том же наборе,
    что и для full backup (см. backup_rules.xml).
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="vip_access_prefs.xml" />
        <include domain="sharedpref" path="vip_extension_used_codes.xml" />
        <include domain="database" path="aura_chat.db" />
        <include domain="sharedpref" path="aura_experience_v1.xml" />
        <include domain="sharedpref" path="aura_progress_counters_v1.xml" />
        <include domain="sharedpref" path="aura_app_uptime_prefs.xml" />
        <include domain="sharedpref" path="aura_au_secure_v1.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="vip_access_prefs.xml" />
        <include domain="sharedpref" path="vip_extension_used_codes.xml" />
        <include domain="database" path="aura_chat.db" />
        <include domain="sharedpref" path="aura_experience_v1.xml" />
        <include domain="sharedpref" path="aura_progress_counters_v1.xml" />
        <include domain="sharedpref" path="aura_app_uptime_prefs.xml" />
        <include domain="sharedpref" path="aura_au_secure_v1.xml" />
    </device-transfer>
</data-extraction-rules>
